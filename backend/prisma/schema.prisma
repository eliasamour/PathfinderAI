generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  createdAt    DateTime @default(now())

  profile              Profile?
  chatSessions         ChatSession[]
  orientationRequests  OrientationRequest[]
}

model Profile {
  id          String  @id @default(uuid())
  userId      String  @unique
  profileType String  @default("lyceen")
  currentSchool       String?
  formation           String?
  level               String?
  filiere             String?
  specialites         String?
  previousSchool      String?
  previousFiliere     String?
  previousSpecialites String?
  currentPath         String?
  previousPath        String?
  budgetMax           Float?
  address             String?
  mobilityType        String? @default("all")
  updatedAt           DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  grades        AcademicGrade[]
  mobilityZones MobilityZone[]
}

model AcademicGrade {
  id          String  @id @default(uuid())
  profileId   String
  subject     String
  grade       Float
  subjectType String  @default("tronc_commun")
  source      String  @default("manual")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model MobilityZone {
  id        String @id @default(uuid())
  profileId String
  zoneType  String
  value     String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id               String   @id @default(uuid())
  userId           String
  status           String   @default("active")
  extractedProfile String?
  createdAt        DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  content   String
  choices   String?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model OrientationRequest {
  id         String   @id @default(uuid())
  userId     String
  userInput  String
  sourceType String   @default("direct")
  chatSessionId String?
  createdAt  DateTime @default(now())

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  results OrientationResult[]
}

model OrientationResult {
  id        String   @id @default(uuid())
  requestId String
  idealPath String
  altPaths  String
  aiComment String
  createdAt DateTime @default(now())

  request OrientationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Formation {
  id             Int     @id @default(autoincrement())
  gta            String  @unique
  nom            String
  typeFormation  String
  filiere        String
  etablissement  String
  region         String
  departement    String
  commune        String
  isPublic       Boolean
  isApprentissage Boolean
  ficheUrl       String?
  lat            Float?
  lon            Float?
  etabUrl        String?
}